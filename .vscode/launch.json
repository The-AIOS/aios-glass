{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run AIOS Glass (Extension Dev Host)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${userHome}/obsidian"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
